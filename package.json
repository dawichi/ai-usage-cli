{
  "name": "ai-usage-cli",
  "version": "0.1.2",
  "description": "Small terminal dashboard for comparing remaining usage between Claude Code and Codex.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ai-usage-cli": "usage-dashboard.mjs"
  },
  "files": [
    "src",
    "usage-dashboard.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node usage-dashboard.mjs",
    "once": "node usage-dashboard.mjs --once",
    "watch": "node usage-dashboard.mjs --interval 60",
    "json": "node usage-dashboard.mjs --once --json",
    "test": "node --test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "codex",
    "dashboard",
    "cli",
    "usage",
    "quota"
  ]
}
